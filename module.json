{
  "id": "worldsmith-foundry-import",
  "title": "Worldsmith Foundry Import",
  "description": "Convert and import Worldsmith creature/companion JSON exports into Foundry VTT as fully-statted dnd5e NPC actors.",
  "version": "1.0.0",
  "authors": [
    {
      "name": "Neon"
    }
  ],
  "compatibility": {
    "minimum": "13",
    "verified": "14"
  },
  "relationships": {
    "systems": [
      {
        "id": "dnd5e",
        "type": "system",
        "manifest": "https://raw.githubusercontent.com/foundryvtt/dnd5e/master/system.json",
        "compatibility": {
          "minimum": "5.0.0",
          "verified": "5.3.3"
        }
      }
    ],
    "recommends": [
      {
        "id": "item-piles",
        "type": "module",
        "manifest": "https://github.com/fantasycalendar/FoundryVTT-ItemPiles/releases/latest/download/module.json",
        "reason": "Shop imports become Item Piles merchant actors."
      }
    ]
  },
  "esmodules": [
    "scripts/module.mjs"
  ],
  "styles": [
    "styles/worldsmith-import.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "url": "https://github.com/worldsmith-foundry-import/worldsmith-foundry-import",
  "manifest": "https://github.com/neonbasschild/WorldsmithFoundryImport/releases/latest/download/module.json",
  "download": "https://github.com/neonbasschild/WorldsmithFoundryImport/releases/download/v1.0.0/module.zip",
  "license": "MIT",
  "readme": "README.md"
}
