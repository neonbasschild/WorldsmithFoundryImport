<div class="worldsmith-import standard-form">
  <p class="hint">{{localize "WORLDSMITH.Intro"}}</p>

  <div class="form-group">
    <label>{{localize "WORLDSMITH.Files"}}</label>
    <div class="form-fields">
      <input type="file" name="files" accept=".json,application/json" multiple>
    </div>
    <p class="hint">{{localize "WORLDSMITH.FilesHint"}}</p>
  </div>

  <div class="form-group stacked">
    <label>{{localize "WORLDSMITH.Paste"}}</label>
    <textarea name="json" rows="10" placeholder="{{localize "WORLDSMITH.PastePlaceholder"}}"></textarea>
  </div>

  <div class="form-group">
    <label>{{localize "WORLDSMITH.Folder"}}</label>
    <div class="form-fields">
      <select name="folder">
        <option value="">{{localize "WORLDSMITH.NoFolder"}}</option>
        {{#each folders}}
        <option value="{{this.id}}">{{this.name}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "WORLDSMITH.OpenSheet"}}</label>
    <div class="form-fields">
      <input type="checkbox" name="renderSheet">
    </div>
  </div>
</div>

<footer class="form-footer">
  {{#each buttons}}
  <button type="{{this.type}}" {{#if this.action}}data-action="{{this.action}}"{{/if}}>
    <i class="{{this.icon}}"></i> {{localize this.label}}
  </button>
  {{/each}}
</footer>
