    },
    "7d7d6452-c48d-48c3-9cd5-66b1a758e685": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Born into the sprawling Seppun line of Rokugan’s imperial household, Seppun Genji is so far down the succession that he will never inherit the throne. Rather than sulk, he throws himself into courtly intrigues, amorous escapades, and harmless pranks. Though his family scolds him for risking scandal, his quick wit and genuine warmth endear him to many—and mask the loneliness of a royal destined to remain in the shadows.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
      "parentId": "b3568d69-0232-4201-8153-b67daf4ae56f",
      "styles": {
        "paddingBottom": "8px"
      },
      "id": "7d7d6452-c48d-48c3-9cd5-66b1a758e685"
    },
