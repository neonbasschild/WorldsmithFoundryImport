    "c79e7470-7bea-47af-955d-db8c77bc13c3": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "{{Prince_Seppun_Genji}}",
              "variable": true,
              "textFormat": "paragraph"
            },
            {
              "text": " can make two attacks on his turn: one with his rapier and one with his dagger.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
      "parentId": "b3568d69-0232-4201-8153-b67daf4ae56f",
      "id": "c79e7470-7bea-47af-955d-db8c77bc13c3"
    },
    "a277e73e-44e0-4ed9-bc24-0c0f97c44eee": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Rapier: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "Melee Weapon Attack: +5 to hit, reach 5 ft., one target. Hit: 1d8+3 piercing damage.",
              "textFormat": "paragraph"
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Dagger: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "Melee or Ranged Weapon Attack: +5 to hit, reach 5 ft. or range 20/60 ft., one target. Hit: 1d4+3 piercing damage.",
              "textFormat": "paragraph"
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Charming Jest (Recharge 5–6): ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "Genji offers a disarming bow or a playful flourish at one creature he can see within 30 ft. The target must succeed on a DC 13 Wisdom saving throw or be charmed by him until the end of his next turn. While charmed this way, the creature regards him as a friendly acquaintance.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
      "parentId": "b3568d69-0232-4201-8153-b67daf4ae56f",
