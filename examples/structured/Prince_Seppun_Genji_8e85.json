    "7653f4cd-cc22-4ce3-b242-95278b888032": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Tall and handsome, with long black hair bound in the traditional Seppun topknot, Genji dresses in brightly colored silks that set him apart from more austere courtiers. His easy smile and mischievous glint draw attention wherever he goes.",
              "textFormat": "description"
            }
          ]
        }
      ],
      "parentId": "b3568d69-0232-4201-8153-b67daf4ae56f",
      "styles": {
        "paddingBottom": "8px"
      },
      "id": "7653f4cd-cc22-4ce3-b242-95278b888032"
    },
    "642d6675-416c-4185-961d-7e907c7b96c1": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Lore",
              "textFormat": "underline-h2"
            }
          ]
        }
      ],
      "parentId": "b3568d69-0232-4201-8153-b67daf4ae56f",
