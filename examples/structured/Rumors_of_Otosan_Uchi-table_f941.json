            {
              "content": [
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "A hidden shrine beneath the Imperial Palace is said to house a trapped kami yearning for freedom. (Wis (Insight) DC 13)",
                      "textFormat": "red"
                    }
                  ]
                }
              ],
              "isHeader": false
            }
