              "isHeader": false
            },
            {
              "content": [
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "The inner tea house of Clan Phoenix convenes a clandestine meeting to overturn the shogun’s advisors. (Wis (Insight) DC 12)",
                      "textFormat": "red"
                    }
                  ]
                }
              ],
              "isHeader": false
            }
