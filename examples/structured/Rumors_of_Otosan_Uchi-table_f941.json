              "isHeader": false
            },
            {
              "content": [
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "A phantom footman bearing the imperial crest distributes scrolls foretelling the Emperor’s demise. (Wis (Insight) DC 14)",
                      "textFormat": "red"
                    }
                  ]
                }
              ],
              "isHeader": false
            }
