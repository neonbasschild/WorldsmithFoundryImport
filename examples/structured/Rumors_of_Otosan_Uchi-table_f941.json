            {
              "content": [
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "The Dragon Clan has recruited a rakshasa posing as a simple street performer. (Wis (Insight) DC 15)",
                      "textFormat": "red"
                    }
                  ]
                }
              ],
              "isHeader": false
            }
