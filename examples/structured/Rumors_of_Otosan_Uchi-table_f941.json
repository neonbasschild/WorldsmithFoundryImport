        {
          "type": "paragraph",
          "children": [
            {
              "text": "Use this table when characters gather rumors in the Imperial City of Otosan Uchi. Each result is a whisper circulating among residents, courtiers, and shadowy figures. To discern whether a rumor is true, call for a Wisdom (Insight) check using the DC noted.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
      "parentId": "8c3a7881-2596-4cd6-8851-c004b4f606c5",
