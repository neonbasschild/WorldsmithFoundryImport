              "content": [
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "The netsuke carving on the main gate hides a secret message from a hidden ninja clan. (Wis (Insight) DC 13)",
                      "textFormat": "red"
                    }
                  ]
                }
              ],
              "isHeader": false
