      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Tail Flick: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "When a creature within 5 feet misses Miru with a melee attack, she can impose disadvantage on that creature’s next attack roll before the end of its next turn.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
      "parentId": "2b933e25-d41b-4799-a55a-caf2dc0d278c",
