    "fe659450-ad41-4e9f-b95b-03ed73692d37": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Familiar Bond: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "While within 100 ft of its bonded master, Miru can share her senses. As an action, the master sees and hears through Miru’s eyes and ears until the start of the master’s next turn.",
              "textFormat": "paragraph"
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Keen Senses: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "Miru has advantage on Wisdom (Perception) checks that rely on hearing or smell.",
              "textFormat": "paragraph"
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Illusory Fur: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "Miru has advantage on saving throws against illusion spells and effects.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
      "parentId": "2b933e25-d41b-4799-a55a-caf2dc0d278c",
      "styles": {
        "paddingBottom": "8px"
      },
      "id": "fe659450-ad41-4e9f-b95b-03ed73692d37"
    },
