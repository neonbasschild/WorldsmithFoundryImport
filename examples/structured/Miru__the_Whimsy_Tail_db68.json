    "c7fc005d-3738-47bf-ab22-a95a06d28146": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Bite: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "Melee Weapon Attack: +8 to hit, reach 5 ft., one target. Hit: 1d4 + 6 piercing damage.",
              "textFormat": "paragraph"
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Illusory Trick (At Will): ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "Miru casts the minor illusion cantrip, using Intelligence as her spellcasting ability (spell save DC 12).",
              "textFormat": "paragraph"
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Fox’s Cunning (Recharge 5–6): ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "Miru bestows a moment of clarity on her master. The bonded master may reroll one ability check or saving throw and must use the new roll.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
      "parentId": "2b933e25-d41b-4799-a55a-caf2dc0d278c",
      "styles": {
        "paddingBottom": "8px"
      },
      "id": "c7fc005d-3738-47bf-ab22-a95a06d28146"
    },
