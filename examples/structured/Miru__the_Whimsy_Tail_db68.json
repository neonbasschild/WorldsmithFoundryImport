    "aa7dc28e-ae4c-400e-8c0b-eaab766c4d44": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Miru appears as a small, snowy-white fox with nine slender tails tipped in pale lavender. Her emerald eyes glint with intelligence, and faint motes of silvery light swirl around her when she’s amused.",
              "textFormat": "description"
            }
          ]
        }
      ],
      "parentId": "2b933e25-d41b-4799-a55a-caf2dc0d278c",
      "styles": {
        "paddingBottom": "8px"
      },
      "id": "aa7dc28e-ae4c-400e-8c0b-eaab766c4d44"
    },
    "033ba48c-7c61-43a3-aa2b-2172afeb7eec": {
