    "2e2efb38-1575-4df0-9a6b-089f938f4adc": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Born under a silvered moon at a hidden forest shrine in Rokugan, Miru is one of the rare kitsune that bonds with a mortal as a familiar rather than wandering the spirit world. Revered by local monks for her playful heart, she delights in pranks and illusions, guiding her master through subtle lessons and moonlit mysteries.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
      "parentId": "2b933e25-d41b-4799-a55a-caf2dc0d278c",
      "styles": {
        "paddingBottom": "8px"
      },
      "id": "2e2efb38-1575-4df0-9a6b-089f938f4adc"
    },
