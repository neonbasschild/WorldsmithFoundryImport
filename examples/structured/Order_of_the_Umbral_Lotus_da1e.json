                  "text": "Preserve and expand the Order’s archive of esoteric lore",
                  "textFormat": "paragraph"
                }
              ]
            },
            {
              "type": "list-item",
              "children": [
                {
                  "text": "Maintain the balance of power by influencing imperial policy from the shadows",
                  "textFormat": "paragraph"
                }
              ]
            },
            {
              "type": "list-item",
              "children": [
                {
                  "text": "Prevent outsiders from uncovering world-altering secrets",
                  "textFormat": "paragraph"
                }
              ]
