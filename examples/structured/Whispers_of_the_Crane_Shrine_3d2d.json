      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Forged by a master smith of the Crane Clan at the foot of the Sacred River, this katana was said to carry the spirit of koi that overcame all obstacles.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
