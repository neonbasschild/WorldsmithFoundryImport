    "de76810b-3687-48c4-a2d1-34577161e0d7": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "You gain a +1 bonus to attack and damage rolls made with this weapon. Once per short rest, as a reaction when you would be hit by an attack, you can evoke the Blade’s Whisper: the blade hums with flowing water, granting you a +2 bonus to AC against that attack.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
      "parentId": "36c57881-5834-4079-a5b5-c68d7de61074",
      "styles": {
