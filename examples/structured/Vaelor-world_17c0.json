          "children": [
            {
              "text": "—300 DR — Founding of the Iron Crown",
              "textFormat": "paragraph",
              "bold": true
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "The warrior‐king Aric the Unifier subjugated rival duchies in Solarys, forging the Iron Crown Dominion.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
