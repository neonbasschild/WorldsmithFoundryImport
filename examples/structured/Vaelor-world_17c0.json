          "children": [
            {
              "text": "—80 DR — Rise of the Verdant Accord",
              "textFormat": "paragraph",
              "bold": true
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Ardor’s city‐states formed an alliance under Archdruid Elenaris to repel Sand Tribes and stabilize trade.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
