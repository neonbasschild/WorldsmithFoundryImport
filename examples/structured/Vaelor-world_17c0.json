              "bold": true
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "A colossal earthquake split ",
              "textFormat": "paragraph"
            },
            {
              "text": "{{Vaelor}}",
              "variable": true,
              "textFormat": "paragraph"
            },
            {
              "text": "’s supercontinent, creating the Riftwall that now divides Solarys and Ardoran.",
              "textFormat": "paragraph"
