          "type": "paragraph",
          "children": [
            {
              "text": "—5 DR — Border War Ignites",
              "textFormat": "paragraph",
              "bold": true
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "A dispute over the Silverfen Marsh’s peat beds led to open conflict. Skirmishes now flare along the Riftwall daily, and both sides mobilize for a major campaign.",
              "textFormat": "paragraph"
            }
          ]
        }
