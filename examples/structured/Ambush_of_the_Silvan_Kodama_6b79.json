    "ed538f0c-bccc-4bbd-ab53-92618c4a27ef": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "A slender humanoid of living bark and leaves, the Kodama’s eyes glow emerald. Its limbs twist like vines, and bark plates shift over its form.",
              "textFormat": "description"
            }
          ]
