    "d2c17179-ffaf-48e1-b069-297503b6f0c1": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Ethereal Shift: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "When the Kodama is hit by a melee attack, it can shift partially into the Ethereal Plane, causing the triggering attack to miss. It returns to the Material Plane at the end of its next turn.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
      "parentId": "23f75725-a23f-4a66-89fe-5d8d03cb31eb",
      "styles": {
