    "e64af761-0db2-4d21-9c5e-574ebcaa0433": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "A narrow forest path winds beneath towering cedars whose crimson leaves flutter like prayer flags in a light breeze. Scattered along the way are half-buried torii gates and faded paper charms, their inked prayers to the mountain kami worn by time. Mist coils around knotted roots that snake across the trail, and distant birdsong is punctuated by an eerie whisper that seems to come from the very trees.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
      "parentId": "e9b77a19-8455-4d84-b93e-56aff5235314",
      "id": "e64af761-0db2-4d21-9c5e-574ebcaa0433"
    },
    "9dd9064e-2703-4d3b-8a1c-6e6af72d89f9": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Objective",
              "textFormat": "underline-h2"
            }
          ]
        }
      ],
      "parentId": "e9b77a19-8455-4d84-b93e-56aff5235314",
      "id": "9dd9064e-2703-4d3b-8a1c-6e6af72d89f9"
    },
    "52c15bcd-4c09-4a9f-bd5a-99bd7e7ddeab": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Survive the Kodama’s assault and restore peace to the grove.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
      "parentId": "e9b77a19-8455-4d84-b93e-56aff5235314",
      "id": "52c15bcd-4c09-4a9f-bd5a-99bd7e7ddeab"
    },
    "d920a10f-2ffc-43d1-9e9a-d8380377050e": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Key Features",
              "textFormat": "underline-h2"
            }
          ]
        }
      ],
      "parentId": "e9b77a19-8455-4d84-b93e-56aff5235314",
      "id": "d920a10f-2ffc-43d1-9e9a-d8380377050e"
