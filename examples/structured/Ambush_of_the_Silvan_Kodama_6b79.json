    "001be440-4b57-4fce-98cd-3e07acf620c0": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Forest Stealth: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "The Kodama has advantage on Dexterity (Stealth) checks while in a forest.",
              "textFormat": "paragraph"
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Spirit Form: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "The Kodama can move through a space as narrow as 1 inch wide without squeezing.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
