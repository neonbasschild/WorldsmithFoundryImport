      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Kodama Bark: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "A flexible strip of bark infused with fey magic. Can be used as a spellcasting focus.",
              "textFormat": "paragraph"
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": " (x3)Paper Leaf Charms: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "Three leaf-shaped charms inscribed with purification prayers. Each grants +1 bonus on one saving throw against fear.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
