    "555c24cb-3bec-44ae-b319-ace5e3b883f9": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Ancient Torii Ruins: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "Half-buried gates mark a forgotten shrine. Each gate confers advantage on DC 13 Wisdom (Religion) checks to recall local forest lore.",
              "textFormat": "paragraph"
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Whispering Canopy: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "A constant, unintelligible murmur. Characters passing a DC 12 Wisdom saving throw ignore the first surprise round.",
              "textFormat": "paragraph"
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Uneven Ground: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "Thick bramble and exposed roots cover the path. Movement through the area costs 1 extra foot for every 1 foot moved.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
      "parentId": "e9b77a19-8455-4d84-b93e-56aff5235314",
      "styles": {
        "paddingBottom": "8px"
      },
      "id": "555c24cb-3bec-44ae-b319-ace5e3b883f9"
    },
