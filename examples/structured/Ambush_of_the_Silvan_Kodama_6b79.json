    "2008bbd3-ef16-4988-ae25-4a33e2976440": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Multiattack: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "The Kodama makes two attacks with its Bark Shard.",
              "textFormat": "paragraph"
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Bark Shard: ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "Melee Weapon Attack: +4 to hit, reach 5 ft., one target. Hit: 1d8+2 slashing damage.",
              "textFormat": "paragraph"
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Forest’s Grasp (Recharge 5–6): ",
              "textFormat": "paragraph",
              "bold": true
            },
            {
              "text": "Roots and vines erupt in a 10-foot radius centered on the Kodama. Each creature in the area must succeed on a DC 13 Strength saving throw or become restrained. A restrained creature can use its action to repeat the save, ending the effect on itself on a success.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
      "parentId": "23f75725-a23f-4a66-89fe-5d8d03cb31eb",
      "styles": {
        "paddingBottom": "8px"
      },
      "id": "2008bbd3-ef16-4988-ae25-4a33e2976440"
    },
