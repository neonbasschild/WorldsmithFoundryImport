    "d6477277-851b-4eee-95de-71457ff0bfcc": {
      "type": "simple",
      "content": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "The ",
              "textFormat": "paragraph"
            },
            {
              "text": "{{Silvan_Kodama}}",
              "variable": true,
              "textFormat": "paragraph"
            },
            {
              "text": " is a shy but fierce fey spirit that protects ancient forests in Rokugan. Offended by the desecration of sacred groves, it emerges to drive away intruders with nature’s wrath.",
              "textFormat": "paragraph"
            }
          ]
        }
      ],
